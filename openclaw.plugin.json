{
  "id": "web_search_plus",
  "name": "Web Search Plus",
  "description": "Multi-provider web search with fallback and monthly usage limits",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "providers": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "id": { "type": "string" },
            "type": { "type": "string" },
            "apiKeyEnv": { "type": "string" },
            "apiKey": { "type": "string" },
            "monthlyLimit": { "type": "number" },
            "baseUrl": { "type": "string" },
            "timeoutMs": { "type": "number" },
            "cooldownMs": { "type": "number" },
            "allowedHosts": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["id", "type", "monthlyLimit"]
        }
      },
      "primaryProviderId": { "type": "string" },
      "cooldownMs": { "type": "number" },
      "allowedHosts": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
