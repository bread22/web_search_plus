{
  "id": "web_search_plus",
  "name": "Web Search Plus",
  "description": "Multi-provider web search with fallback and monthly usage limits",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "providers": {
        "type": "array",
        "minItems": 1,
        "maxItems": 20,
        "items": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "id": { "type": "string" },
            "type": { "type": "string", "enum": ["brave", "tavily", "custom"] },
            "apiKey": { "type": "string" },
            "monthlyLimit": { "type": "number" },
            "baseUrl": { "type": "string" }
          },
          "required": ["id", "type", "apiKey", "monthlyLimit"]
        }
      },
      "primaryProviderId": { "type": "string" },
      "customProviderAllowlist": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
